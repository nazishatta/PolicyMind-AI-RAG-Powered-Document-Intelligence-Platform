{
  // PolicyMind-AI — GitHub Codespaces / VS Code Dev Container
  //
  // Opens a fully working development environment with all Python
  // dependencies installed and the API server ready to start.
  // No API keys required: the server defaults to mock mode.
  //
  // Quick start after the container builds:
  //   1. Open a terminal in VS Code.
  //   2. Run: uvicorn backend.app.main:app --reload --port 8000
  //   3. Open the forwarded port 8000  →  /docs  for the Swagger UI.
  //   4. Run the smoke test: python scripts/smoke_test.py
  //   5. Run the full test suite: pytest backend/tests/

  "name": "PolicyMind-AI",

  // Python 3.11 on Debian Bullseye — matches the CI matrix version.
  "image": "mcr.microsoft.com/devcontainers/python:1-3.11-bullseye",

  // ---------------------------------------------------------------------------
  // Post-create: install the package in editable mode with all dev extras.
  // Copies .env.example → .env so the server starts in mock mode immediately.
  // ---------------------------------------------------------------------------
  "postCreateCommand": "pip install -e '.[dev]' && [ -f .env ] || cp .env.example .env",

  // ---------------------------------------------------------------------------
  // Mock-mode environment variables.
  // These are injected into every terminal and process in the container.
  // They are NOT secrets — they select in-memory, offline providers only.
  // To use a real LLM, set ANTHROPIC_API_KEY or OPENAI_API_KEY in .env and
  // change LLM_PROVIDER accordingly; never commit .env to version control.
  // ---------------------------------------------------------------------------
  "remoteEnv": {
    "LLM_PROVIDER": "mock",
    "VECTOR_STORE_PROVIDER": "chroma",
    "GRAPH_PROVIDER": "memory",
    "PYTHONDONTWRITEBYTECODE": "1",
    "PYTHONIOENCODING": "utf-8"
  },

  // ---------------------------------------------------------------------------
  // Port forwarding — the API and Swagger UI are accessible in the browser.
  // ---------------------------------------------------------------------------
  "forwardPorts": [8000],
  "portsAttributes": {
    "8000": {
      "label": "PolicyMind-AI API",
      "onAutoForward": "notify"
    }
  },

  // ---------------------------------------------------------------------------
  // VS Code extensions installed automatically in the container.
  // ---------------------------------------------------------------------------
  "customizations": {
    "vscode": {
      "extensions": [
        "ms-python.python",
        "ms-python.vscode-pylance",
        "charliermarsh.ruff",
        "42crunch.vscode-openapi",
        "redhat.vscode-yaml",
        "tamasfe.even-better-toml"
      ],
      "settings": {
        "python.defaultInterpreterPath": "/usr/local/bin/python",
        "editor.formatOnSave": true,
        "editor.rulers": [100],
        "[python]": {
          "editor.defaultFormatter": "charliermarsh.ruff"
        },
        "ruff.enable": true
      }
    }
  }
}
