# ============================================================
#  PolicyMind-AI — Environment Variables
#  Copy to .env and fill in your values. Never commit .env.
# ============================================================

# --- LLM Provider -------------------------------------------
# Choose one: "anthropic" | "openai" | "mock"
# "mock" requires no API key and is safe for CI / local demos.
LLM_PROVIDER=mock

# Anthropic (required if LLM_PROVIDER=anthropic)
ANTHROPIC_API_KEY=

# OpenAI (required if LLM_PROVIDER=openai)
OPENAI_API_KEY=your_key_here

# Groq — free tier available at console.groq.com (used if OPENAI_API_KEY is empty)
GROQ_API_KEY=

# Optional: override the default model for the chosen provider
# Anthropic default: claude-sonnet-4-6
# OpenAI default:    gpt-4o
LLM_MODEL=

LLM_TEMPERATURE=0.0
LLM_MAX_TOKENS=2048

# --- Embeddings (local, no API key needed) ------------------
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2
EMBEDDING_DEVICE=cpu

# --- Vector Store -------------------------------------------
# "chroma" (persistent, local) | "memory" (ephemeral, tests)
VECTOR_STORE_PROVIDER=chroma
CHROMA_PERSIST_DIR=./data/chroma
CHROMA_COLLECTION=policy_chunks

# --- Graph Layer --------------------------------------------
# "memory" (NetworkX, no setup) | "neo4j" (bolt connection)
GRAPH_PROVIDER=memory

# Neo4j (required only when GRAPH_PROVIDER=neo4j)
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=
NEO4J_DATABASE=neo4j

# --- Document Ingestion -------------------------------------
MAX_DOCUMENT_SIZE_MB=50

# --- Chunking -----------------------------------------------
CHUNK_SIZE=1000
CHUNK_OVERLAP=150
TOP_K_RESULTS=5

# --- Streamlit layer paths ----------------------------------
RAW_DATA_DIR=data/raw
PROCESSED_DATA_DIR=data/processed
CHROMA_DB_PATH=vector_db/chroma
EMBEDDING_MODEL_NAME=sentence-transformers/all-MiniLM-L6-v2

# --- RAG confidence routing (Streamlit layer) ---------------
# Minimum avg relevance score for a "Document Answer" (grounded in uploaded docs).
# Scores between CONFIDENCE_THRESHOLD and 0.20 produce a "Partial Answer".
# Scores below 0.20 produce a "General Answer" from model knowledge.
CONFIDENCE_THRESHOLD=0.35
# Set to false to disable the general-knowledge fallback entirely.
FALLBACK_ENABLED=true

# --- Application --------------------------------------------
DEBUG=false
LOG_LEVEL=INFO
